{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://depviz.dev/schemas/lock-v1.schema.json",
  "title": "Depviz Conda Lock v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "schema_version",
    "lock_id",
    "created_at",
    "resolution_digest",
    "resolution",
    "artifacts"
  ],
  "properties": {
    "schema": { "const": "depviz.conda-lock" },
    "schema_version": { "const": 1 },
    "lock_id": { "$ref": "#/$defs/sha256" },
    "created_at": { "type": "string", "format": "date-time" },
    "resolution_digest": { "$ref": "#/$defs/sha256" },
    "resolution": { "type": "object" },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/artifact" }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "build", "platform", "source", "url", "checksum"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "build": { "type": "string", "minLength": 1 },
        "platform": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "minLength": 1 },
        "checksum": {
          "type": "string",
          "pattern": "^(sha256:[0-9a-f]{64}|md5:[0-9a-f]{32})$"
        }
      }
    }
  }
}
